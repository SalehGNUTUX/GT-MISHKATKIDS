{
  "name": "tilmithi",
  "private": true,
  "version": "1.5.3",
  "type": "module",
  "description": "تلميذي — الطفل يُعلّم الآليّ فيتذكّر ويتعافى (محليّ، بلا اتصال، بلا ذكاء اصطناعي)",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/SalehGNUTUX/GT-MISHKATKIDS",
  "author": "SalehGNUTUX <gnutux.arabic@gmail.com>",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "gen:audio": "node tools/gen-audio.mjs",
    "gen:custom": "node tools/gen-custom.mjs",
    "gen:voices": "node tools/gen-voices.mjs",
    "gen:piper": "node tools/gen-piper.mjs",
    "gen:quran": "node tools/gen-quran.mjs",
    "gen:icons": "node tools/gen-fa-icons.mjs",
    "pkg:linux": "bash scripts/build-packages.sh linux",
    "pkg:apk": "bash scripts/build-packages.sh apk",
    "pkg:all": "bash scripts/build-packages.sh all"
  },
  "build": {
    "appId": "com.gnutux.gtmishkatkids",
    "productName": "GT-MISHKATKIDS",
    "copyright": "© 2026 SalehGNUTUX — GNU GPL v3",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Education",
      "maintainer": "SalehGNUTUX <gnutux.arabic@gmail.com>",
      "synopsis": "تطبيق تعليمي إسلامي للأطفال — الطفل يُعلّم الآليّ",
      "description": "مِشكاةُ الطفلِ والآليّ: تطبيقٌ تعليميٌّ إسلاميٌّ للأطفال (4–10) يعمل محلّيًّا دون إنترنت.",
      "desktop": {
        "Name": "مِشكاةُ الطفلِ والآليّ",
        "Comment": "تطبيق تعليمي إسلامي للأطفال (4–10) — محلّيّ دون إنترنت",
        "Keywords": "kids;islamic;education;quran;arabic;children;",
        "Categories": "Education;"
      }
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.AppImage"
    },
    "deb": {
      "artifactName": "${productName}-${version}-${arch}.deb"
    },
    "rpm": {
      "artifactName": "${productName}-${version}-${arch}.rpm"
    }
  },
  "dependencies": {
    "jspdf": "^4.2.1"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.2",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.3",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "html2canvas": "^1.4.1",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  }
}
